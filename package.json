{
  "name": "@shindou/rules-cli",
  "type": "module",
  "version": "0.1.12",
  "packageManager": "pnpm@10.33.0",
  "description": "Manage and sync AI Agent rules across 30+ coding assistants via symlink",
  "author": "hikaru",
  "license": "MIT",
  "homepage": "https://github.com/shindouhiro/rules-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shindouhiro/rules-cli.git"
  },
  "bugs": {
    "url": "https://github.com/shindouhiro/rules-cli/issues"
  },
  "readmeFilename": "README.md",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "rules": "dist/cli.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "README.en.md",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown && vite build --config vite.ui.config.ts",
    "dev": "tsdown --watch",
    "dev:ui": "vite --config vite.ui.config.ts",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "prepare": "npx simple-git-hooks",
    "prepack": "pnpm build",
    "release": "bumpp -r",
    "start": "node dist/cli.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "catalog:prod",
    "@iconify/vue": "catalog:prod",
    "@shikijs/monaco": "catalog:prod",
    "cac": "catalog:prod",
    "consola": "catalog:prod",
    "monaco-editor-core": "catalog:prod",
    "ofetch": "catalog:prod",
    "picocolors": "catalog:prod",
    "shiki": "catalog:prod",
    "vue": "catalog:prod"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@types/node": "catalog:dev",
    "@vitejs/plugin-vue": "catalog:dev",
    "autoprefixer": "catalog:dev",
    "bumpp": "catalog:dev",
    "eslint": "catalog:dev",
    "lint-staged": "catalog:dev",
    "postcss": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "tailwindcss": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
